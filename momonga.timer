<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>もぐもぐポモドーロ</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #FFF8ED;
    --cream-card: #FFFEFA;
    --tomato: #FF6B4A;
    --tomato-dark: #E5502F;
    --leaf: #4CAF7D;
    --leaf-dark: #379563;
    --hamster: #C97B3D;
    --hamster-light: #E8B984;
    --plum: #3A2E39;
    --sunny: #FFC857;
    --line: #F0E4D2;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    min-height: 100vh;
    background: var(--cream);
    background-image:
      radial-gradient(circle at 15% 20%, rgba(255,200,87,0.18) 0%, transparent 35%),
      radial-gradient(circle at 85% 80%, rgba(76,175,125,0.14) 0%, transparent 40%);
    font-family: 'Nunito', sans-serif;
    color: var(--plum);
    display: flex;
    justify-content: center;
    padding: 32px 16px 60px;
  }

  .app {
    width: 100%;
    max-width: 420px;
  }

  .eyebrow {
    text-align: center;
    font-family: 'Fredoka', sans-serif;
    font-weight: 500;
    letter-spacing: 0.08em;
    font-size: 13px;
    color: var(--hamster);
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  h1 {
    font-family: 'Fredoka', sans-serif;
    font-weight: 700;
    text-align: center;
    font-size: 30px;
    margin: 0 0 20px;
    color: var(--plum);
  }

  .card {
    background: var(--cream-card);
    border-radius: 32px;
    padding: 28px 24px 24px;
    box-shadow: 0 12px 0 rgba(58,46,57,0.06), 0 20px 40px rgba(58,46,57,0.08);
    border: 2px solid var(--line);
  }

  /* Hamster desk scene */
  .scene {
    position: relative;
    height: 190px;
    margin: 0 auto 8px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .scene svg { overflow: visible; }

  #paw-left, #paw-right {
    transform-origin: center top;
    animation: type-left 0.5s infinite ease-in-out;
  }
  #paw-right { animation-name: type-right; animation-delay: 0.25s; }

  @keyframes type-left {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-4px) rotate(-6deg); }
  }
  @keyframes type-right {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-4px) rotate(6deg); }
  }

  #ear-left, #ear-right {
    transform-origin: center bottom;
    animation: twitch 3.2s infinite ease-in-out;
  }
  #ear-right { animation-delay: 1.6s; }
  @keyframes twitch {
    0%, 92%, 100% { transform: rotate(0deg); }
    95% { transform: rotate(8deg); }
  }

  .zzz { opacity: 0; }
  .scene.resting #zzz-group { opacity: 1; }
  .scene.resting .work-anim { animation-play-state: paused; }
  .scene.resting #paw-left, .scene.resting #paw-right { animation: none; transform: translateY(0); }

  #zzz-group text {
    font-family: 'Fredoka', sans-serif;
    font-weight: 600;
    fill: var(--hamster);
    opacity: 0;
  }
  .scene.resting #zzz-group text.z1 { animation: floatz 2.4s infinite ease-in; }
  .scene.resting #zzz-group text.z2 { animation: floatz 2.4s infinite ease-in; animation-delay: 0.6s; }
  .scene.resting #zzz-group text.z3 { animation: floatz 2.4s infinite ease-in; animation-delay: 1.2s; }
  @keyframes floatz {
    0% { opacity: 0; transform: translate(0,0); }
    20% { opacity: 1; }
    100% { opacity: 0; transform: translate(10px,-24px); }
  }

  .scene.celebrate .hamster-body { animation: jump 0.6s ease-in-out 2; }
  @keyframes jump {
    0%, 100% { transform: translateY(0); }
    40% { transform: translateY(-18px) rotate(-4deg); }
    60% { transform: translateY(-18px) rotate(4deg); }
  }

  .confetti { opacity: 0; }
  .scene.celebrate .confetti { opacity: 1; }
  .scene.celebrate .confetti rect {
    animation: confetti-fall 1.1s ease-in forwards;
  }
  @keyframes confetti-fall {
    0% { transform: translateY(-10px) rotate(0deg); opacity: 1; }
    100% { transform: translateY(70px) rotate(280deg); opacity: 0; }
  }

  /* Mode toggle */
  .mode-toggle {
    display: flex;
    background: var(--cream);
    border-radius: 999px;
    padding: 4px;
    margin: 18px 0 6px;
    border: 2px solid var(--line);
  }
  .mode-toggle button {
    flex: 1;
    border: none;
    background: transparent;
    font-family: 'Fredoka', sans-serif;
    font-weight: 600;
    font-size: 14px;
    padding: 9px 0;
    border-radius: 999px;
    color: var(--plum);
    opacity: 0.55;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .mode-toggle button.active {
    opacity: 1;
    color: white;
  }
  .mode-toggle button[data-mode="focus"].active { background: var(--tomato); box-shadow: 0 3px 0 var(--tomato-dark); }
  .mode-toggle button[data-mode="rest"].active { background: var(--leaf); box-shadow: 0 3px 0 var(--leaf-dark); }

  /* Timer */
  .timer {
    text-align: center;
    font-family: 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: 68px;
    line-height: 1;
    margin: 14px 0 4px;
    letter-spacing: 0.02em;
    color: var(--plum);
    font-variant-numeric: tabular-nums;
  }
  .status-label {
    text-align: center;
    font-size: 14px;
    font-weight: 800;
    color: var(--hamster);
    margin-bottom: 18px;
    min-height: 18px;
  }

  .controls {
    display: flex;
    gap: 10px;
  }
  .btn {
    flex: 1;
    border: none;
    font-family: 'Fredoka', sans-serif;
    font-weight: 600;
    font-size: 16px;
    padding: 14px 0;
    border-radius: 18px;
    cursor: pointer;
    transition: transform 0.08s ease;
  }
  .btn:active { transform: translateY(2px); }
  .btn-primary {
    background: var(--tomato);
    color: white;
    box-shadow: 0 4px 0 var(--tomato-dark);
  }
  .btn-primary.running {
    background: var(--sunny);
    color: var(--plum);
    box-shadow: 0 4px 0 #D9A93E;
  }
  .btn-secondary {
    background: transparent;
    color: var(--plum);
    border: 2px solid var(--line);
    box-shadow: none;
    flex: 0 0 auto;
    padding: 14px 18px;
  }

  .custom-time {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 12px;
    font-size: 12px;
    color: var(--plum);
    opacity: 0.6;
  }
  .custom-time button {
    background: none;
    border: none;
    text-decoration: underline;
    font-family: 'Nunito', sans-serif;
    font-size: 12px;
    color: var(--hamster);
    cursor: pointer;
    padding: 4px;
  }

  /* Stats */
  .stats {
    margin-top: 22px;
    padding-top: 20px;
    border-top: 2px dashed var(--line);
  }
  .stats-row {
    display: flex;
    justify-content: space-around;
    text-align: center;
    margin-bottom: 16px;
  }
  .stat-num {
    font-family: 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: 24px;
  }
  .stat-label {
    font-size: 12px;
    opacity: 0.65;
    font-weight: 700;
  }

  .week-chart {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    height: 64px;
    gap: 8px;
  }
  .day-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    height: 100%;
  }
  .day-bar {
    width: 100%;
    max-width: 26px;
    background: var(--tomato);
    border-radius: 8px 8px 4px 4px;
    min-height: 4px;
    transition: height 0.4s ease;
  }
  .day-bar.today { background: var(--leaf); }
  .day-name {
    font-size: 10px;
    font-weight: 800;
    opacity: 0.55;
    margin-top: 6px;
  }

  .reset-link {
    text-align: center;
    margin-top: 18px;
  }
  .reset-link button {
    background: none;
    border: none;
    font-size: 11px;
    color: var(--plum);
    opacity: 0.35;
    cursor: pointer;
    text-decoration: underline;
    font-family: 'Nunito', sans-serif;
  }

  @media (prefers-reduced-motion: reduce) {
    * { animation: none !important; transition: none !important; }
  }
</style>
</head>
<body>
<div class="app">
  <div class="eyebrow">Focus Timer</div>
  <h1>もぐもぐポモドーロ 🐹</h1>

  <div class="card">
    <div class="scene" id="scene">
      <svg viewBox="0 0 220 170" width="220" height="170">
        <!-- desk -->
        <rect x="10" y="128" width="200" height="14" rx="6" fill="#E8D9BE"/>
        <rect x="24" y="142" width="14" height="20" rx="3" fill="#D9C6A3"/>
        <rect x="182" y="142" width="14" height="20" rx="3" fill="#D9C6A3"/>
        <!-- laptop -->
        <g transform="translate(70,96)">
          <rect x="0" y="18" width="60" height="6" rx="2" fill="#B0A390"/>
          <rect x="6" y="-20" width="48" height="38" rx="4" fill="#5B5062"/>
          <rect x="9" y="-17" width="42" height="30" rx="2" fill="#8FD9FF"/>
        </g>
        <!-- sunflower seed pile -->
        <ellipse cx="182" cy="130" rx="14" ry="6" fill="var(--sunny)" opacity="0.5"/>
        <!-- hamster body group -->
        <g class="hamster-body" transform="translate(110,90)">
          <ellipse cx="0" cy="30" rx="34" ry="16" fill="rgba(58,46,57,0.08)"/>
          <!-- body -->
          <ellipse cx="0" cy="10" rx="30" ry="24" fill="var(--hamster-light)"/>
          <ellipse cx="0" cy="16" rx="20" ry="14" fill="#F6E4CC"/>
          <!-- head -->
          <circle cx="0" cy="-16" r="24" fill="var(--hamster)"/>
          <circle cx="0" cy="-10" r="17" fill="#F6E4CC"/>
          <!-- ears -->
          <circle id="ear-left" cx="-18" cy="-32" r="9" fill="var(--hamster)"/>
          <circle id="ear-right" cx="18" cy="-32" r="9" fill="var(--hamster)"/>
          <circle cx="-18" cy="-32" r="4.5" fill="#F2C7A6"/>
          <circle cx="18" cy="-32" r="4.5" fill="#F2C7A6"/>
          <!-- eyes -->
          <g id="eyes-open">
            <circle cx="-8" cy="-14" r="3" fill="var(--plum)"/>
            <circle cx="8" cy="-14" r="3" fill="var(--plum)"/>
          </g>
          <!-- cheeks -->
          <circle cx="-14" cy="-4" r="6" fill="#F5B0A0" opacity="0.7"/>
          <circle cx="14" cy="-4" r="6" fill="#F5B0A0" opacity="0.7"/>
          <!-- nose -->
          <circle cx="0" cy="-2" r="2.5" fill="#C97B3D"/>
          <!-- paws -->
          <g class="work-anim">
            <ellipse id="paw-left" cx="-16" cy="18" rx="7" ry="6" fill="#F6E4CC"/>
            <ellipse id="paw-right" cx="16" cy="18" rx="7" ry="6" fill="#F6E4CC"/>
          </g>
        </g>
        <!-- zzz -->
        <g id="zzz-group" class="zzz">
          <text class="z1" x="150" y="40" font-size="18">z</text>
          <text class="z2" x="162" y="28" font-size="22">Z</text>
          <text class="z3" x="176" y="14" font-size="26">Z</text>
        </g>
        <!-- confetti -->
        <g class="confetti">
          <rect x="60" y="20" width="6" height="6" fill="var(--tomato)"/>
          <rect x="90" y="10" width="6" height="6" fill="var(--sunny)"/>
          <rect x="120" y="16" width="6" height="6" fill="var(--leaf)"/>
          <rect x="150" y="24" width="6" height="6" fill="var(--tomato)"/>
          <rect x="75" y="30" width="6" height="6" fill="var(--leaf)"/>
          <rect x="135" y="8" width="6" height="6" fill="var(--sunny)"/>
        </g>
      </svg>
    </div>

    <div class="mode-toggle">
      <button data-mode="focus" class="active">集中</button>
      <button data-mode="rest">休憩</button>
    </div>

    <div class="timer" id="timerDisplay">25:00</div>
    <div class="status-label" id="statusLabel">がんばって集中しよう</div>

    <div class="controls">
      <button class="btn btn-primary" id="startBtn">スタート</button>
      <button class="btn btn-secondary" id="resetBtn">↺</button>
    </div>

    <div class="custom-time" id="customTime">
      <span>集中時間:</span>
      <button data-min="15">15分</button>
      <button data-min="25">25分</button>
      <button data-min="45">45分</button>
    </div>

    <div class="stats">
      <div class="stats-row">
        <div>
          <div class="stat-num" id="streakNum">0</div>
          <div class="stat-label">🔥 連続日数</div>
        </div>
        <div>
          <div class="stat-num" id="todayNum">0</div>
          <div class="stat-label">今日の回数</div>
        </div>
        <div>
          <div class="stat-num" id="totalNum">0</div>
          <div class="stat-label">合計回数</div>
        </div>
      </div>
      <div class="week-chart" id="weekChart"></div>
    </div>

    <div class="reset-link">
      <button id="clearData">記録をリセット</button>
    </div>
  </div>
</div>

<audio id="dingSound" preload="auto">
  <source src="data:audio/wav;base64,UklGRiQAAABXQVZFZm10IBAAAAABAAEAQB8AAEAfAAABAAgAZGF0YQAAAAA=" type="audio/wav">
</audio>

<script>
(function(){
  const STORAGE_KEY = 'mogumogu-pomodoro-data';
  const FOCUS_DEFAULT = 25 * 60;
  const REST_DEFAULT = 5 * 60;

  let mode = 'focus';
  let focusMinutes = 25;
  let secondsLeft = FOCUS_DEFAULT;
  let timerInterval = null;
  let running = false;

  const scene = document.getElementById('scene');
  const timerDisplay = document.getElementById('timerDisplay');
  const statusLabel = document.getElementById('statusLabel');
  const startBtn = document.getElementById('startBtn');
  const resetBtn = document.getElementById('resetBtn');
  const modeButtons = document.querySelectorAll('.mode-toggle button');
  const customTimeButtons = document.querySelectorAll('#customTime button');
  const streakNum = document.getElementById('streakNum');
  const todayNum = document.getElementById('todayNum');
  const totalNum = document.getElementById('totalNum');
  const weekChart = document.getElementById('weekChart');
  const clearDataBtn = document.getElementById('clearData');

  function formatTime(s) {
    const m = Math.floor(s / 60).toString().padStart(2, '0');
    const sec = (s % 60).toString().padStart(2, '0');
    return m + ':' + sec;
  }

  function todayKey(d) {
    d = d || new Date();
    return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
  }

  let data = { sessions: {}, totalCount: 0 };

  async function loadData() {
    try {
      const result = await window.storage.get(STORAGE_KEY, false);
      if (result && result.value) {
        data = JSON.parse(result.value);
      }
    } catch (e) {
      data = { sessions: {}, totalCount: 0 };
    }
    renderStats();
  }

  async function saveData() {
    try {
      await window.storage.set(STORAGE_KEY, JSON.stringify(data), false);
    } catch (e) {
      console.error('保存に失敗しました', e);
    }
  }

  function computeStreak() {
    let streak = 0;
    let d = new Date();
    // if today has no sessions, streak counts backward from yesterday but still show 0 if none today and none yesterday chain
    while (true) {
      const key = todayKey(d);
      if (data.sessions[key] && data.sessions[key] > 0) {
        streak++;
        d.setDate(d.getDate() - 1);
      } else {
        break;
      }
    }
    return streak;
  }

  function renderStats() {
    const tKey = todayKey();
    const today = data.sessions[tKey] || 0;
    streakNum.textContent = computeStreak();
    todayNum.textContent = today;
    totalNum.textContent = data.totalCount || 0;

    // week chart: last 7 days
    weekChart.innerHTML = '';
    const dayNames = ['日','月','火','水','木','金','土'];
    let maxVal = 1;
    const days = [];
    for (let i = 6; i >= 0; i--) {
      const d = new Date();
      d.setDate(d.getDate() - i);
      const key = todayKey(d);
      const val = data.sessions[key] || 0;
      days.push({ val, dayName: dayNames[d.getDay()], isToday: i === 0 });
      if (val > maxVal) maxVal = val;
    }
    days.forEach(day => {
      const col = document.createElement('div');
      col.className = 'day-col';
      const bar = document.createElement('div');
      bar.className = 'day-bar' + (day.isToday ? ' today' : '');
      const heightPct = Math.max(6, (day.val / maxVal) * 100);
      bar.style.height = heightPct + '%';
      const label = document.createElement('div');
      label.className = 'day-name';
      label.textContent = day.dayName;
      col.appendChild(bar);
      col.appendChild(label);
      weekChart.appendChild(col);
    });
  }

  async function recordSession() {
    const key = todayKey();
    data.sessions[key] = (data.sessions[key] || 0) + 1;
    data.totalCount = (data.totalCount || 0) + 1;
    await saveData();
    renderStats();
  }

  function setMode(newMode, resetTimer) {
    mode = newMode;
    modeButtons.forEach(b => b.classList.toggle('active', b.dataset.mode === mode));
    if (resetTimer !== false) {
      stopTimer();
      secondsLeft = mode === 'focus' ? focusMinutes * 60 : REST_DEFAULT;
      updateDisplay();
    }
    statusLabel.textContent = mode === 'focus' ? 'がんばって集中しよう' : 'ゆっくり休憩しよう';
    scene.classList.remove('celebrate');
    scene.classList.toggle('resting', mode === 'rest');
  }

  function updateDisplay() {
    timerDisplay.textContent = formatTime(secondsLeft);
  }

  function startTimer() {
    if (running) return;
    running = true;
    startBtn.textContent = 'ストップ';
    startBtn.classList.add('running');
    scene.classList.remove('celebrate');
    scene.classList.toggle('resting', mode === 'rest');
    timerInterval = setInterval(() => {
      secondsLeft--;
      updateDisplay();
      if (secondsLeft <= 0) {
        finishSession();
      }
    }, 1000);
  }

  function stopTimer() {
    running = false;
    clearInterval(timerInterval);
    startBtn.textContent = 'スタート';
    startBtn.classList.remove('running');
  }

  async function finishSession() {
    stopTimer();
    scene.classList.remove('resting');
    scene.classList.add('celebrate');
    if (mode === 'focus') {
      statusLabel.textContent = 'よくやった!ひと休みしよう 🎉';
      await recordSession();
      setTimeout(() => setMode('rest'), 1400);
    } else {
      statusLabel.textContent = 'また集中モードに戻ろう';
      setTimeout(() => setMode('focus'), 1400);
    }
  }

  startBtn.addEventListener('click', () => {
    if (running) {
      stopTimer();
      scene.classList.toggle('resting', mode === 'rest');
    } else {
      startTimer();
    }
  });

  resetBtn.addEventListener('click', () => {
    stopTimer();
    secondsLeft = mode === 'focus' ? focusMinutes * 60 : REST_DEFAULT;
    updateDisplay();
    scene.classList.remove('celebrate');
    scene.classList.toggle('resting', mode === 'rest');
    statusLabel.textContent = mode === 'focus' ? 'がんばって集中しよう' : 'ゆっくり休憩しよう';
  });

  modeButtons.forEach(btn => {
    btn.addEventListener('click', () => setMode(btn.dataset.mode));
  });

  customTimeButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      focusMinutes = parseInt(btn.dataset.min, 10);
      if (mode === 'focus' && !running) {
        secondsLeft = focusMinutes * 60;
        updateDisplay();
      }
    });
  });

  clearDataBtn.addEventListener('click', async () => {
    if (confirm('記録をすべてリセットしますか?この操作は取り消せません。')) {
      data = { sessions: {}, totalCount: 0 };
      await saveData();
      renderStats();
    }
  });

  updateDisplay();
  loadData();
})();
</script>
</body>
</html>
